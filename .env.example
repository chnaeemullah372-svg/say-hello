# Copy this to `.env` on the VPS (it's gitignored, so it won't come from git).
# Get the real values from your Supabase project settings (Project Settings > API).
SUPABASE_PROJECT_ID="your-project-ref"
SUPABASE_PUBLISHABLE_KEY="your-anon-public-key"
SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_PROJECT_ID="your-project-ref"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-public-key"

# Only needed on the VPS, for scripts/send-due-reminders.mjs (cron job).
# Get this from Supabase -> Project Settings -> API -> service_role.
# NEVER expose this in the frontend bundle or a VITE_ variable.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
